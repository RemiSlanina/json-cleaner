                if (cleanedResult == null)
                {
                    Console.WriteLine("Error! Null cleanedResult == null"); 
                }
                if (cleanedResult!.Remove) { 
                    changesMade++; // here or in CleanJson? 
                    continue; 
                } // else:  
                // for null values: 
                if (cleanedResult.Value == null) newobject[item.Key] = null; 
                // for none null values: 
                else newobject[item.Key] = cleanedResult!.Value!.DeepClone(); // node already has a parent, might be a problem here
            }
            Console.WriteLine("returning jsonArray + ", JsonSerializer.Serialize(newobject) );
            return new TraverseResult
            {
