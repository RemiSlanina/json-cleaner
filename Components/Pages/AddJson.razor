    // fetch the string provided by the user, sanitiy check it and deserialize 
    private async Task FetchInput(){
        Console.WriteLine("-----------------------------------------------"); 
        Console.WriteLine("start"); 
        Console.WriteLine("-----------------------------------------------"); 
        changesMade = 0; // reset counter for each turn 
        // sanity check: only use valid json. 
        // deserialization and exceptions
        try {
            if (jsonInput == "") return; 
            parsedJson = JsonNode.Parse(jsonInput); 
            @* Console.WriteLine("josn: " + deserializedJson); *@
            errorMessage = "";
        } catch (JsonException) {
            Console.WriteLine("Invalid JSON syntax. Please check your input.");
            errorMessage = "Invalid JSON syntax. Please check your input.";
            return; 
        }
        // process it depending on user input: 
        result = parsedJson != null ? ProcessJson(parsedJson) : new JsonObject(); 
        @* await Task.Delay(millisecondsDelay: 500); *@
        // serialize and output 
        await ProvideJsonOutput(result); 
    } 

    private JsonNode? ProcessJson(JsonNode? json){
        // for testing, set cleanActions to a given value: 
        cleanActions = new List<CleanAction>(); 
        cleanActions.Add(CleanAction.RemoveEmptyStrings); 
        Console.WriteLine("json input: " + JsonSerializer.Serialize(json));
        @* Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(json));  *@
        Console.WriteLine(); 

        if (json == null) return new JsonObject(); 
        if (actionChoice == KeyActionOption.RemoveEmptyKeys) { 
            json = RemoveEmptyKeys(json);  
        } 
        if (actionChoice == KeyActionOption.FillMissingKeys) {
            json = FillMissingKeys(json!); // ! = null-forgiving operator 
        } 
        if (cleanActions != null && cleanActions.Count> 0) {
            @* debugging = "inside TraverseTree loop"; *@
            TraverseResult? traversed = TraverseTree(json!, cleanActions); 
            if (traversed != null) json = traversed.Value; 
            else Console.WriteLine("Error - TraverseTree returned Null in ProcessJson!");
            
        }
        
        @* if (removeEmptyStrings){
            json = RemoveEmptyStrings(json); 
        } *@

        return json; 
    } 


    private TraverseResult? CleanJson(JsonNode json, List<CleanAction>? cleanActions) { 
        if (cleanActions!.Count == 0) return new TraverseResult{ Remove = false, Value = json }; 
        foreach (CleanAction c in cleanActions) {
            switch (c) 
            {
                case CleanAction.RemoveEmptyStrings: 
                Console.WriteLine("Removing empty strings"); // TO DO 
                if (json is not JsonValue jsonValue) break; 
                @* if (jsonValue.GetValueKind() == JsonValueKind.Null) return jsonValue;  *@
                if (jsonValue.GetValueKind() == JsonValueKind.Null) break; 
                if (jsonValue.GetValueKind() == JsonValueKind.String) {
                    string str = jsonValue.GetValue<string>(); 
                    if (str == "") {
                        //changesMade++;  // do that here?  ..nop
                        return new TraverseResult
                        {
                            Remove = true, Value = jsonValue 
                        }; 
                    }
                    @* string str = JsonSerializer.Serialize(jsonValue); 
                    if (str == "\"\"") return null;  *@
                    return new TraverseResult
                        {
                            Remove = false, Value = jsonValue 
                        }; 
                } 
                break; 
                case CleanAction.RemoveEmptyArrays: 
                Console.WriteLine("Removing empty arrays"); // TO DO 
                break; 
                case CleanAction.TrimWhitespace: 
                Console.WriteLine("Trim Whitespace selected"); // TO DO 
                break; 
                case CleanAction.RemoveZeroValues: 
                Console.WriteLine("Removing Zero Values"); // TO DO 
                break; 
                default: 
                Console.WriteLine("No valid CleanAction."); 
                break; 
            } 
        }
        
        return new TraverseResult{ Remove = false, Value = json }; 
    }

    // -----------------------------------------------------------
    // to-do 
